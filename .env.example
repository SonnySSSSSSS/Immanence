# Immanence OS Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase auth configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth gate
# Secure default is enabled. Set to false only for explicit local smoke flows.
VITE_ENABLE_AUTH=true

# LLM Proxy URL
# For local development: http://localhost:8787
# For production: https://immanence-llm-proxy.YOUR-SUBDOMAIN.workers.dev
VITE_LLM_PROXY_URL=http://localhost:8787
