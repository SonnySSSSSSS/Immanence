{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(del /f*)",
      "Bash(rmdir /s*)",
      "Bash(format *)",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)"
    ]
  },
  "mcpServers": {
    "comfyui": {
      "command": "node",
      "args": [
        "tools/comfyui-mcp-server.js"
      ],
      "env": {
        "COMFYUI_URL": "http://127.0.0.1:8188"
      }
    }
  }
}
