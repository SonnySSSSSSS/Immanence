{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Skill(update-config:*)",
      "WebFetch(domain:codesandbox.io)"
    ]
  },
  "mcpServers": {
    "comfyui": {
      "command": "node",
      "args": [
        "tools/comfyui-mcp-server.js"
      ],
      "env": {
        "COMFYUI_URL": "http://127.0.0.1:8188"
      }
    }
  }
}
